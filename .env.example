PORT=3000
DATA_DIR=/data
NAS_SHARE_PATH=/mnt/nas
FACE_DETECTION_ENABLED=false
LOG_LEVEL=info
# Optional override for stitched video playback mode selection.
# Default behavior: true on ARM/ARM64 hosts (e.g. Raspberry Pi), false otherwise.
# STITCHED_PREFER_COMPATIBILITY=true

# OpenTelemetry — set OTEL_EXPORTER_OTLP_ENDPOINT to enable (leave blank to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ourtube
# OTEL_SDK_DISABLED=true
# OTEL_LOG_LEVEL=debug

# Docker Compose host port overrides (optional)
OTEL_COLLECTOR_OTLP_GRPC_HOST_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_HOST_PORT=4318
OTEL_COLLECTOR_PROMETHEUS_EXPORTER_HOST_PORT=9464
JAEGER_UI_HOST_PORT=16686
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001
