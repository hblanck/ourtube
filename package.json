{
  "name": "ourtube",
  "version": "1.0.0",
  "description": "YouTube-like video manager for NAS libraries",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "admin:key:create": "node src/admin-key-cli.js create",
    "test": "jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/sdk-node": "^0.216.0",
    "better-sqlite3": "^9.4.3",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "fluent-ffmpeg": "^2.1.2",
    "mime-types": "^2.1.35",
    "morgan": "^1.10.0",
    "node-schedule": "^2.1.1",
    "sharp": "^0.33.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
